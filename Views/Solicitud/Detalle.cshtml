@model PlataformaCreditos.Models.SolicitudCredito
@{
    ViewData["Title"] = "Detalle de Solicitud";
}

<h2>Detalle de Solicitud #@Model.Id</h2>

<div class="card mt-3">
    <div class="card-body">
        <p><strong>Monto Solicitado:</strong> S/. @Model.MontoSolicitado</p>
        <p><strong>Fecha de Solicitud:</strong> @Model.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Estado:</strong> 
            <span class="badge @(Model.Estado == PlataformaCreditos.Models.EstadoSolicitud.Aprobado ? "bg-success" : Model.Estado == PlataformaCreditos.Models.EstadoSolicitud.Rechazado ? "bg-danger" : "bg-warning")">
                @Model.Estado
            </span>
        </p>
        @if (!string.IsNullOrEmpty(Model.MotivoRechazo))
        {
            <p><strong>Motivo de Rechazo:</strong> @Model.MotivoRechazo</p>
        }
    </div>
</div>

<a href="/Solicitud/Index" class="btn btn-secondary mt-3">Volver a mis solicitudes</a>